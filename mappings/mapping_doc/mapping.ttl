@prefix segittur: <https://ontologia.segittur.es/turismo/def/core#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix gsp: <http://www.opengis.net/ont/geosparql#>.
@prefix ex: <http://example.org/turismo/>.
@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix formats: <http://www.w3.org/ns/formats/>.
@prefix comp: <http://semweb.mmlab.be/ns/rml-compression#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#>.
@prefix map: <http://mapping.example.com/> .
@prefix map: <http://mapping.example.com/> .
@prefix dct: <http://purl.org/dc/terms/>.
@base <http://example.com/ns#>.
@base <http://example.com/ns#>.

map:person_000 dct:contributor foaf:Person ;
    rdfs:label "Jhon Toledo" ;
    foaf:mbox <mailto:ja.toledo@upm.es> .

map:rules_000 schema:contributor map:person_000 ;
    rdf:type schema:Dataset ;
    schema:version "1.0.0" ;
    schema:title "Mappings RML para transformar datos turísticos a RDF (Ontología de Turismo)" ;
    schema:dateCreated "20-04-2026" ;
    schema:description "Este conjunto de mappings RML transforma datos del dominio turístico a RDF, utilizando una ontología de turismo. El objetivo es generar un grafo RDF interoperable para representar las entidades principales del sector turístico, como destinos, alojamientos, actividades, recursos turísticos y servicios asociados, orientado a su reutilización e integración en sistemas semánticos." .

<hotel_mapping_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "dataset.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/alojamiento/hotel/{id_origen}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant segittur:Hotel;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:registrationNumber;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "num_registro";
			rr:datatype xsd:string
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:name;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "nombre";
			rr:datatype xsd:string
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:numberOfAccomodationUnits;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "unidades_alojamiento";
			rr:datatype xsd:int
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:numberOfBeds;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "plazas_camas";
			rr:datatype xsd:int
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:accomodationRating;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/Rating_{id_origen}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:hasDescription;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/Desc_{id_origen}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:hasContactPoint;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/Contact_{id_origen}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant segittur:hasLocation;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/location/Location_{id_origen}";
			rr:termType rr:IRI
		];
	].


